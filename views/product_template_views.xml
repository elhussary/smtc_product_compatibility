<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_inherit_compatibility" model="ir.ui.view">
        <field name="name">product.template.form.compatibility</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">
                <page string="Compatibility" name="compatibility_matrix">
                    <group>
                        <group>
                            <field name="compatible_brand_ids" widget="many2many_tags"
                                options="{'no_create': True}" />

                            <field name="compatible_connection_ids"
                                widget="many2many_tags"
                                domain="[('brand_id', 'in', compatible_brand_ids)]"
                                options="{'no_create': True}" />
                        </group>
                    </group>
                </page>
            </xpath>

        </field>
    </record>
</odoo>