<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Override product name in Shop Grid to show selected Brand + Connection -->
    <template id="shop_product_compatibility_name" inherit_id="website_sale.products_item">
        <xpath
            expr="//h2[contains(@class, 'o_wsale_products_item_title')]//a/span[@t-field='product.name']"
            position="replace">
            <t t-set="compat_brand" t-value="selected_brands[0] if selected_brands else False" />
            <t t-set="compat_conn"
                t-value="selected_connections[0] if selected_connections else False" />

            <t t-set="suffix" t-value="''" />
            <t t-if="compat_brand">
                <t t-set="suffix" t-value="compat_brand.name" />
            </t>
            <t t-if="compat_conn">
                <t t-set="suffix" t-value="(suffix + ' ' if suffix else '') + compat_conn.name" />
            </t>

            <t t-if="suffix">
                <span t-out="product.name + ' for ' + suffix" />
            </t>
            <t t-else="">
                <span t-field="product.name" />
            </t>
        </xpath>
    </template>

    <!-- Override product title on product detail page -->
    <template id="product_title_compatibility" inherit_id="website_sale.product_title">
        <xpath expr="//h1[@t-field='product.name']" position="replace">
            <t t-set="compat_brand" t-value="selected_brands[:1] if selected_brands else False" />
            <t t-set="compat_conn"
                t-value="selected_connections[:1] if selected_connections else False" />
            <t t-set="title_name" t-value="product.name" />
            <t t-if="compat_brand or compat_conn">
                <t t-set="suffix" t-value="''" />
                <t t-if="compat_conn">
                    <t t-set="suffix" t-value="compat_conn[0].name" />
                </t>
                <t t-if="compat_brand">
                    <t t-set="suffix"
                        t-value="compat_brand[0].name + (' ' + suffix if suffix else '')" />
                </t>
                <t t-set="title_name" t-value="product.name + ' for ' + suffix" />
            </t>
            <h1
                t-attf-class="h3 {{'mb-3' if not product.description_ecommerce and not is_view_active('website_sale.product_comment') else ''}}">
                <span t-esc="title_name" />
            </h1>
        </xpath>
    </template>

    <!-- Override Specifications Table to filter Brand/Connection and add Reference row -->
    <template id="specs_table_filtered" inherit_id="website_sale_comparison.specifications_table">
        <xpath expr="//table" position="replace">
            <t t-set="display_brands"
                t-value="product.compatible_brand_ids.filtered(lambda b: b.id in selected_brand_ids) if selected_brand_ids else product.compatible_brand_ids" />
            <t t-set="display_connections"
                t-value="product.compatible_connection_ids.filtered(lambda c: c.id in selected_connection_ids) if selected_connection_ids else product.compatible_connection_ids" />

            <table t-attf-class="table {{is_accordion and 'table-sm mb-0'}}">
                <t t-if="len(attrib_categories) &gt; 1 and not is_accordion">
                    <tr>
                        <th class="text-start" colspan="2">
                            <span t-if="category" t-field="category.name" />
                            <span t-else="">Others</span>
                        </th>
                    </tr>
                </t>

                <!-- Brand row -->
                <t t-if="display_brands">
                    <tr>
                        <td class="w-25 ps-0">Compatibility</td>
                        <td class="w-75 pe-0 text-muted text-end">
                            <t t-foreach="display_brands" t-as="brand">
                                <span t-esc="brand.name" />
                                <t t-if="not brand_last">, </t>
                            </t>
                        </td>
                    </tr>
                </t>

                <!-- Connection row -->
                <t t-if="display_connections">
                    <tr>
                        <td class="w-25 ps-0">Connection</td>
                        <td class="w-75 pe-0 text-muted text-end">
                            <t t-foreach="display_connections" t-as="connection">
                                <span t-esc="connection.name" /> (<span
                                    t-esc="connection.brand_id.name" />)<t
                                    t-if="not connection_last">, </t>
                            </t>
                        </td>
                    </tr>
                </t>

                <!-- Reference row: Internal Ref / Brand Ref -->
                <t
                    t-if="product_variant and (product_variant.default_code or (display_brands and display_brands[:1].reference))">
                    <tr>
                        <td class="w-25 ps-0">Reference</td>
                        <td id="spec_reference_value" class="w-75 pe-0 text-end fw-bold text-dark"
                            t-att-data-brand-ref="display_brands[:1].reference if display_brands and display_brands[:1].reference else ''">

                            <t t-if="display_brands and display_brands[:1].reference"
                                t-esc="display_brands[:1].reference" />

                            <t
                                t-if="display_brands and display_brands[:1].reference and product_variant.default_code">
                                <span></span>
                            </t>

                            <t t-if="product_variant.default_code"
                                t-esc="product_variant.default_code" />
                        </td>
                    </tr>
                </t>

                <!-- Other attributes -->
                <t
                    t-foreach="attrib_categories[category].filtered(lambda l: len(l.value_ids) &gt; 1 and l.attribute_id.name not in ('Brand', 'Connection'))"
                    t-as="ptal">
                    <t t-set="hide_border_bottom_classes"
                        t-value="'border-bottom-0' if ptal_last and is_accordion else ''" />
                    <tr>
                        <td t-attf-class="w-25 {{hide_border_bottom_classes}} ps-0">
                            <span t-field="ptal.attribute_id.name" />
                        </td>
                        <td
                            t-attf-class="w-75 {{hide_border_bottom_classes}} pe-0 text-muted text-end">
                            <t t-foreach="ptal.value_ids" t-as="pav">
                                <span t-field="pav.name" />
                                <t t-if="not pav_last">, </t>
                            </t>
                        </td>
                    </tr>
                </t>

                <!-- Other attributes -->
                <t t-set="single_value_attributes"
                    t-value="attrib_categories[category]._prepare_single_value_for_display()" />
                <t t-foreach="single_value_attributes" t-as="attribute">
                    <t t-if="attribute.name not in ('Brand', 'Connection')">
                        <t t-set="hide_border_bottom_classes"
                            t-value="'border-bottom-0' if attribute_last and is_accordion else ''" />
                        <tr>
                            <td t-attf-class="w-25 {{hide_border_bottom_classes}} ps-0">
                                <span t-field="attribute.name" />
                            </td>
                            <td
                                t-attf-class="w-75 {{hide_border_bottom_classes}} pe-0 text-muted text-end">
                                <t t-foreach="single_value_attributes[attribute]" t-as="ptal">
                                    <span
                                        t-field="ptal.product_template_value_ids._only_active().name" />
                                    <t t-if="not ptal_last">, </t>
                                </t>
                            </td>
                        </tr>
                    </t>
                </t>
            </table>
        </xpath>
    </template>
</odoo>