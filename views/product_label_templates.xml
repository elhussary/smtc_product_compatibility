<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Override ALL label formats to show brand ref + brand name. -->

    <!-- 2 x 7 with price label -->
    <template id="label_brand_ref_2x7" inherit_id="product.report_simple_label2x7">
        <xpath expr="//span[@t-field='product.default_code']" position="replace">
            <t t-set="compat_brands" t-value="product.product_tmpl_id.compatible_brand_ids" />
            <t t-set="first_brand" t-value="compat_brands[:1]" />
            <span class="text-nowrap">
                <t t-if="product.default_code and first_brand and first_brand.reference">
                    <t t-esc="product.default_code" />/<t t-esc="first_brand.reference" />
                </t>
                <t t-elif="product.default_code">
                    <t t-esc="product.default_code" />
                </t>
            </span>
            <t t-if="first_brand">
                <br />
                <small class="text-muted">
                    <t t-esc="first_brand.name" />
                </small>
            </t>
        </xpath>
    </template>

